//   R7=0x00000004 (4),  R8=0x00000008 (8)

10001100000000010000000000000001    // [0x00] lw   $1, 1($0)        ; R1 = MEM[1] = 1
10001100000000100000000000000010    // [0x04] lw   $2, 2($0)        ; R2 = MEM[2] = 2
10001100000000110000000000000011    // [0x08] lw   $3, 3($0)        ; R3 = MEM[3] = 3
10000000000000000000000000000000    // [0x0C] NOP                   ; load-use bubble (lw#3 -> first add)
00000000001000100000100000100000    // [0x10] add  $1, $1, $2       ; R1 = 1 + 2 = 3   (forwards R1 from MEM/WB, R2 from EX/MEM)
00000000001000110000100000100000    // [0x14] add  $1, $1, $3       ; R1 = 3 + 3 = 6   (forwards R1 from EX/MEM)
00000000001000010000100000100000    // [0x18] add  $1, $1, $1       ; R1 = 6 + 6 = 12  (forwards R1 from EX/MEM)
00000000001000000000100000100000    // [0x1C] add  $1, $1, $0       ; R1 = 12 + 0 = 12 (R0 reads as 0)
10001100000001110000000000000100    // [0x20] lw   $7, 4($0)        ; R7 = MEM[4] = 4
00000000111001110100000000100000    // [0x24] add  $8, $7, $7       ; R8 = R7 + R7 = 8 (load-use: hazard unit inserts 1 bubble)